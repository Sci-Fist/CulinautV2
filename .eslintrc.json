{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "complexity": ["error", 8],
    "no-unused-vars": "warn",
    "no-console": "off",
    "max-lines-per-function": ["warn", 50]
  }
}
